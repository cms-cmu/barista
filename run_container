run_classifier() {
    check_apptainer
    info "Running Classifier container..."

    local INIT_FILE="/entrypoint.sh"
    local USE_SLURM=false
    local IS_CPU=false
    local IMAGE="$CLASSIFIER_IMAGE"  # Default to GPU
    touch "$PWD/.python_history"
    local FLAGS=( -B "$PWD":/srv --nv --pwd /srv -B /tmp:/tmp
        --env PYTHONHISTFILE=/srv/.python_history
    )
    ulimit -n 65536

    # Detect if on FALCON (auto-enable SLURM)
    local HOST=$(hostname)
    if [[ $HOST == *falcon* ]]; then
        USE_SLURM=true
        info "FALCON cluster detected. Will submit jobs via SLURM."
    fi

    # Handle CPU flag (passed from dispatcher as first arg if classifier_cpu)
    if [[ "$1" == "cpu" ]]; then
        info "Using CPU version of the classifier container..."
        IMAGE="$CLASSIFIER_CPU_IMAGE"
        IS_CPU=true
        shift  # Remove "cpu" from args
    else
        info "Using GPU version of the classifier container..."
    fi

    # Collect remaining user arguments
    local USER_CMD="$*"

    # CPU: Handle FALCON / BRIDGES2 interactive session
    if [ "$IS_CPU" = true ] && [ -z "$USER_CMD" ] && [[ $HOST == *falcon* || $HOST == *bridges2* || $HOST == *psc* ]]; then
        if [ -n "$SLURM_JOB_ID" ]; then
            # Already inside a job
            info "Inside Slurm Job ($SLURM_JOB_ID). Opening interactive CPU classifier shell..."
        else
            # Login node - submit interactive job
            if [[ $HOST == *bridges2* || $HOST == *psc* ]]; then
                info "Not in a job. Launching interactive Slurm session..."
                local ACCOUNT_ARG=()
                [ -n "${SLURM_ACCOUNT:-}" ] && ACCOUNT_ARG=( -A "${SLURM_ACCOUNT}" )
                srun --pty --partition=RM-shared "${ACCOUNT_ARG[@]}" --time=02:00:00 --cpus-per-task=2 --mem=4000M "$0" classifier_cpu
            else
                info "Not in a job. Launching interactive Slurm session..."
                srun --pty --partition=work --time=04:00:00 --mem=4G "$0" classifier_cpu
            fi
            return
        fi
    fi

    # GPU: Handle FALCON / BRIDGES2 interactive session
    if [ "$IS_CPU" = false ] && [ -z "$USER_CMD" ] && [[ $HOST == *falcon* || $HOST == *bridges2* || $HOST == *psc* ]]; then
        if [ -n "$SLURM_JOB_ID" ]; then
            # Already inside a job
            info "Inside Slurm Job ($SLURM_JOB_ID). Opening interactive GPU classifier shell..."
        else
            # Login node - submit interactive GPU job
            if [[ $HOST == *bridges2* || $HOST == *psc* ]]; then
                info "Not in a job. Launching interactive GPU Slurm session with --gres=gpu:1..."
                local ACCOUNT_ARG=()
                [ -n "${SLURM_ACCOUNT:-}" ] && ACCOUNT_ARG=( -A "${SLURM_ACCOUNT}" )
                srun --pty --partition=GPU-shared "${ACCOUNT_ARG[@]}" --time=04:00:00 --cpus-per-task=4 --mem=8000M --gres=gpu:1 "$0" classifier
            else
                info "Not in a job. Launching interactive GPU Slurm session with --gres=mps:20..."
                srun --pty --partition=work --time=04:00:00 --mem=4G --gres=mps:20 "$0" classifier
            fi
            return
        fi
    fi

    add_x509_proxy_flags "$HOST" FLAGS

    # Execute
    if [ "$USE_SLURM" = true ] && [ -n "$USER_CMD" ]; then
        # FALCON with command: submit to SLURM
        local SLURM_CONF="${SLURM_CONF:-software/slurm/slurm.conf}"
        mkdir -p slurm_logs
        local CMD="source $INIT_FILE && export PYTHONUNBUFFERED=1 && $USER_CMD"
        local SLURM_GRES_ARGS=()
        if [ "$IS_CPU" = false ]; then
            SLURM_GRES_ARGS=( --gres=mps:20 )
        fi

        info "Submitting batch job to Slurm (config: $SLURM_CONF)..."
        { echo "#!/bin/bash"; cat "$SLURM_CONF"; echo "${APPTAINER_CMD:-apptainer} exec ${FLAGS[@]} \"$IMAGE\" bash -c \"$CMD\""; } | sbatch "${SLURM_GRES_ARGS[@]}"
    elif [ -z "$USER_CMD" ]; then
        # Interactive (FALCON job or non-FALCON)
        APPTAINER_SHELL=$(which bash) "${APPTAINER_CMD:-apptainer}" exec "${FLAGS[@]}" "$IMAGE" bash --init-file "$INIT_FILE"
    else
        # CPU with command or non-FALCON GPU/CPU with command
        APPTAINER_SHELL=$(which bash) "${APPTAINER_CMD:-apptainer}" exec "${FLAGS[@]}" "$IMAGE" bash --init-file "$INIT_FILE" -c "$USER_CMD"
    fi
}

