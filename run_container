# --- Helpers ---
info() { echo -e "\033[1;34m[INFO]\033[0m $1" >&2; }
error() { echo -e "\033[1;31m[ERROR]\033[0m $1" >&2; }
warning() { echo -e "\033[1;33m[WARNING]\033[0m $1" >&2; }

check_apptainer() {
    command -v apptainer >/dev/null 2>&1 || { error "Apptainer is not installed. Aborting."; exit 1; }
}

add_x509_proxy_flags() {
    local HOST="$1"
    local -n FLAGS_REF="$2"

    case "$HOST" in
        *cmslpc*|*lxplus*|*falcon*|*rogue*|*bridges2*|*psc*)
            local PROXY="${PWD}/proxy/x509_proxy"
            mkdir -p proxy
            
            # Construct apptainer flags for proxy operations
            local PROXY_FLAGS=( -B "${HOME}/.globus:${HOME}/.globus" )
            if [[ "${PWD}" != "${HOME}"* ]]; then
                PROXY_FLAGS+=( -B "${PWD}:${PWD}" --pwd "${PWD}" )
            fi
            if [ -d "/cvmfs/grid.cern.ch/etc/grid-security/certificates" ]; then
                PROXY_FLAGS+=( -B /cvmfs --env X509_CERT_DIR=/cvmfs/grid.cern.ch/etc/grid-security/certificates )
            fi

            # Check if proxy is valid
            local PROXY_VALID=false
            if command -v voms-proxy-info >/dev/null 2>&1; then
                if voms-proxy-info --file "$PROXY" --exists -valid 6:00 &>/dev/null; then
                    PROXY_VALID=true
                fi
            else
                if "${APPTAINER_CMD:-apptainer}" exec "${PROXY_FLAGS[@]}" "$COFFEA_IMAGE" voms-proxy-info --file "$PROXY" --exists -valid 6:00 &>/dev/null; then
                    PROXY_VALID=true
                fi
            fi

            if [ "$PROXY_VALID" = false ]; then
                if [ ! -t 0 ]; then
                    error "No valid Grid proxy found at $PROXY and stdin is not a TTY. Please initialize the proxy interactively by running run_container once from the login node before submitting batch jobs."
                    exit 1
                fi
                if command -v voms-proxy-init >/dev/null 2>&1; then
                    voms-proxy-init -voms cms -valid 192:00 -out "$PROXY"
                else
                    info "Host does not have voms-proxy-init. Attempting to generate proxy using the container..."
                    if [[ "$CLUSTER_PROFILE" == "bridges2" ]]; then
                        warning "On Bridges 2, generating proxy inside the container without VOMS attributes to avoid OOM-kill."
                        "${APPTAINER_CMD:-apptainer}" exec "${PROXY_FLAGS[@]}" "$COFFEA_IMAGE" voms-proxy-init -valid 192:00 -out "$PROXY"
                    else
                        "${APPTAINER_CMD:-apptainer}" exec "${PROXY_FLAGS[@]}" "$COFFEA_IMAGE" voms-proxy-init -voms cms -valid 192:00 -out "$PROXY"
                    fi
                fi
            fi

            if [ -f "$PROXY" ]; then
                FLAGS_REF+=( -B "$PROXY":"$PROXY" --env X509_USER_PROXY="$PROXY" )
            fi
            ;;
    esac
}

