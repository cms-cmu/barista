# --- Pixi / Snakemake Local ---

install_pixi() {
    if ! command -v pixi &> /dev/null; then
        if [ -x "${PIXI_DIR}/bin/pixi" ]; then
            export PATH="${PIXI_DIR}/bin:$PATH"
        else
            info "Installing Pixi to ${PIXI_DIR}..."
            export PIXI_HOME="${PIXI_DIR}"
            mkdir -p "${PIXI_DIR}"
            curl -fsSL https://pixi.sh/install.sh | bash >&2 || return 1
            export PATH="${PIXI_DIR}/bin:$PATH"
        fi
    fi
    command -v pixi &> /dev/null || return 1
}

run_snakemake() {
    local HOST
    HOST=$(hostname)
    
    if [[ $HOST == *bridges2* || $HOST == *psc* ]]; then
        if [ -z "$SLURM_JOB_ID" ]; then
            info "Not in a job on Bridges-2. Launching Snakemake scheduler inside interactive Slurm session..."
            local ACCOUNT_ARG=()
            [ -n "${SLURM_ACCOUNT:-}" ] && ACCOUNT_ARG=( -A "${SLURM_ACCOUNT}" )
            exec srun --pty --partition=RM-shared "${ACCOUNT_ARG[@]}" --time=04:00:00 --cpus-per-task=2 --mem=8000M "$0" snakemake "$@"
        fi
    fi

    # Note: on falcon, Snakemake runs directly on the login node (lightweight scheduler).
    # Heavy work is submitted to Slurm via the snakemake-executor-plugin-slurm.

    info "Running Snakemake with Pixi environment..."
    set -eo pipefail

    local REINSTALL=false
    local ARGS=()
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            --reinstall|--fresh) REINSTALL=true; shift ;;
            --help|-h) ARGS+=("--help"); shift ;;
            source) ARGS+=("$@"); break ;;
            *) ARGS+=("$1"); shift ;;
        esac
    done

    [[ ${#ARGS[@]} -eq 0 && "$REINSTALL" != true ]] && { error "No arguments supplied."; show_help; exit 1; }

    # Install Pixi
    install_pixi || { error "Pixi installation failed."; exit 1; }

    # Reinstall logic
    if [ "$REINSTALL" = true ]; then
        info "Cleaning up environment..."
        rm -rf .pixi
    fi

    # Install Environment
    pixi install || { error "Pixi install failed."; exit 1; }

    # Auto-inject cluster profile if user didn't specify one
    local HAS_PROFILE=false
    for arg in "${ARGS[@]}"; do
        if [[ "$arg" == "--profile" ]]; then
            HAS_PROFILE=true
            break
        fi
    done
    if [ "$HAS_PROFILE" = false ]; then
        # Use lpc_combine profile for combine/stat-analysis workflows; base profile for everything else.
        local AUTO_PROFILE="${PROFILE_DIR}/${CLUSTER_PROFILE}"
        local IS_COMBINE=false
        for arg in "${ARGS[@]}"; do
            if [[ "$arg" == *combine.smk* || "$arg" == *stat_analysis* || "$arg" == *Snakefile_combine* ]]; then
                IS_COMBINE=true
                break
            fi
        done
        if $IS_COMBINE && [ -d "${PROFILE_DIR}/${CLUSTER_PROFILE}_combine" ]; then
            AUTO_PROFILE="${PROFILE_DIR}/${CLUSTER_PROFILE}_combine"
        fi
        if [ -d "$AUTO_PROFILE" ]; then
            info "Auto-injecting Snakemake profile: $AUTO_PROFILE"
            ARGS=("--profile" "$AUTO_PROFILE" "${ARGS[@]}")
        fi
    fi

    # Auto-inject Slurm account from $USER if the profile uses the slurm executor
    local ACTIVE_PROFILE_DIR=""
    local i=0
    while [ $i -lt ${#ARGS[@]} ]; do
        if [[ "${ARGS[$i]}" == "--profile" ]] && [ $((i+1)) -lt ${#ARGS[@]} ]; then
            ACTIVE_PROFILE_DIR="${ARGS[$((i+1))]}"
            break
        fi
        i=$((i+1))
    done
    if [ -n "$ACTIVE_PROFILE_DIR" ] && [ -f "$ACTIVE_PROFILE_DIR/config.yaml" ] && grep -q 'executor:.*slurm' "$ACTIVE_PROFILE_DIR/config.yaml"; then
        # Only inject slurm_account on clusters that require it (e.g., lxplus)
        # Falcon uses a default account with no partition association, so skip it
        local PROFILE_NAME
        PROFILE_NAME=$(basename "$ACTIVE_PROFILE_DIR")
        if [[ "$PROFILE_NAME" != "falcon" ]]; then
            info "Auto-injecting Slurm account: $USER"
            ARGS+=("--default-resources" "slurm_account=$USER")
        fi
    fi

    # Execute

    if [ "${ARGS[0]}" = "source" ]; then
        pixi run bash -c "${ARGS[*]}"
    else
        pixi run snakemake "${ARGS[@]}"
    fi
    info "Execution finished successfully!"
}

run_reana() {
    info "Running REANA client with Pixi environment..."
    set -eo pipefail

    local REINSTALL=false
    local ARGS=()
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            --reinstall|--fresh) REINSTALL=true; shift ;;
            --help|-h) ARGS+=("--help"); shift ;;
            source) ARGS+=("$@"); break ;;
            *) ARGS+=("$1"); shift ;;
        esac
    done

    [[ ${#ARGS[@]} -eq 0 && "$REINSTALL" != true ]] && { error "No arguments supplied."; show_help; exit 1; }

    # Install Pixi
    install_pixi || { error "Pixi installation failed."; exit 1; }

    # Reinstall logic
    if [ "$REINSTALL" = true ]; then
        info "Cleaning up environment..."
        rm -rf .pixi
    fi

    # Install Environment
    pixi install -e reana || { error "Pixi install failed."; exit 1; }

    # Execute
    export PYTHONNOUSERSITE=1
    if [ "${ARGS[0]}" = "source" ]; then
        pixi run -e reana bash -c "${ARGS[*]}"
    elif [ "${ARGS[0]}" = "run" ]; then
        # Split `run` into create+upload+start so upload failures don't abort the workflow.
        # reana-client run exits non-zero if any file fails to upload, which kills the pipeline.
        local RUN_ARGS=("${ARGS[@]:1}")  # everything after "run"
        local CREATE_ARGS=() UPLOAD_ARGS=() START_ARGS=() FOLLOW=false
        local i=0
        while [ $i -lt ${#RUN_ARGS[@]} ]; do
            case "${RUN_ARGS[$i]}" in
                -f|--file)        CREATE_ARGS+=("${RUN_ARGS[$i]}" "${RUN_ARGS[$((i+1))]}"); i=$((i+2)) ;;
                -n|-w|--name|--workflow) CREATE_ARGS+=("${RUN_ARGS[$i]}" "${RUN_ARGS[$((i+1))]}"); i=$((i+2)) ;;
                --skip-validation) CREATE_ARGS+=("${RUN_ARGS[$i]}"); i=$((i+1)) ;;
                -p|--parameter)   START_ARGS+=("${RUN_ARGS[$i]}" "${RUN_ARGS[$((i+1))]}"); i=$((i+2)) ;;
                -o|--option)      START_ARGS+=("${RUN_ARGS[$i]}" "${RUN_ARGS[$((i+1))]}"); i=$((i+2)) ;;
                --follow)         FOLLOW=true; i=$((i+1)) ;;
                *)                CREATE_ARGS+=("${RUN_ARGS[$i]}"); i=$((i+1)) ;;
            esac
        done

        info "Creating workflow..."
        WORKFLOW_NAME=$(pixi run -e reana reana-client create "${CREATE_ARGS[@]}" | tail -1)
        info "Workflow created: $WORKFLOW_NAME"

        info "Uploading files (failures are non-fatal)..."
        pixi run -e reana reana-client upload -w "$WORKFLOW_NAME" || true

        info "Starting workflow..."
        if [ "$FOLLOW" = true ]; then
            pixi run -e reana reana-client start -w "$WORKFLOW_NAME" "${START_ARGS[@]}" --follow
        else
            pixi run -e reana reana-client start -w "$WORKFLOW_NAME" "${START_ARGS[@]}"
        fi
    else
        pixi run -e reana reana-client "${ARGS[@]}"
    fi
    info "Execution finished successfully!"
}

