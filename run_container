# --- Host Detection & Setup ---
PIXI_DIR="$HOME/.pixi"
PROFILE_DIR="software/snakemake/profiles"

# Detect which cluster profile to use based on hostname
detect_cluster_profile() {
    local HOST
    HOST=$(hostname)
    case "$HOST" in
        *cmslpcgpu*) echo "lpc_gpu" ;;
        *cmslpc*)  echo "lpc" ;;
        *lxplus*)  echo "lxplus" ;;
        *falcon*)  echo "falcon" ;;
        *rogue*)   echo "rogue" ;;
        *runner*)  echo "ci" ;;
        *bridges2*|*psc*) echo "bridges2" ;;
        *)         echo "default" ;;
    esac
}

# Parse apptainer-args from a Snakemake profile config.yaml
parse_apptainer_args() {
    local CONFIG_FILE="$1"
    if [ -f "$CONFIG_FILE" ]; then
        local raw
        raw=$(sed -n 's/^apptainer-args:[[:space:]]*"\(.*\)"/\1/p' "$CONFIG_FILE")
        # Expand shell variables like ${USER} in bind paths
        raw="${raw//\$\{USER\}/$USER}"
        raw="${raw//\$USER/$USER}"
        echo "$raw"
    fi
}

setup_host_env() {
    # Compute workspace hash to isolate Dask schedulers per worktree/workspace
    WORKSPACE_HASH=$(python3 -c "import hashlib, os; print(hashlib.md5(os.path.abspath(os.path.dirname('$0')).encode('utf-8')).hexdigest()[:8])")

    local HOST
    HOST=$(hostname)
    CLUSTER_PROFILE=$(detect_cluster_profile)
    local PROFILE_CONFIG="${PROFILE_DIR}/${CLUSTER_PROFILE}/config.yaml"
    info "Determining configuration for hostname: $HOST (profile: $CLUSTER_PROFILE)"

    # Set default apptainer executable
    APPTAINER_CMD="apptainer"

    if [[ "$CLUSTER_PROFILE" == "bridges2" ]]; then
        # Resolve SIF files from shared directory if present
        local SHARED_IMAGE_DIR="/ocean/projects/phy260026p/shared/images"
        if [ -f "${SHARED_IMAGE_DIR}/barista_latest.sif" ]; then
            COFFEA_IMAGE="${SHARED_IMAGE_DIR}/barista_latest.sif"
        fi
        if [ -f "${SHARED_IMAGE_DIR}/barista_dev_coffea2025_latest.sif" ]; then
            DEV_COFFEA2025_IMAGE="${SHARED_IMAGE_DIR}/barista_dev_coffea2025_latest.sif"
        fi
        if [ -f "${SHARED_IMAGE_DIR}/combine-container_CMSSW_14_1_0_pre4-combine_v10.6.0-harvester_v3.1.0.sif" ]; then
            COMBINE_IMAGE="${SHARED_IMAGE_DIR}/combine-container_CMSSW_14_1_0_pre4-combine_v10.6.0-harvester_v3.1.0.sif"
        fi
        if [ -f "${SHARED_IMAGE_DIR}/barista_classifier_latest.sif" ]; then
            CLASSIFIER_IMAGE="${SHARED_IMAGE_DIR}/barista_classifier_latest.sif"
        fi
        if [ -f "${SHARED_IMAGE_DIR}/barista_classifier_cpu_latest.sif" ]; then
            CLASSIFIER_CPU_IMAGE="${SHARED_IMAGE_DIR}/barista_classifier_cpu_latest.sif"
        fi
        if [ -f "${SHARED_IMAGE_DIR}/brilws-docker_latest.sif" ]; then
            BRILCALC_IMAGE="${SHARED_IMAGE_DIR}/brilws-docker_latest.sif"
        fi
    fi

    # Parse bind paths from profile config
    local APPTAINER_ARGS
    APPTAINER_ARGS=$(parse_apptainer_args "$PROFILE_CONFIG")
    if [ -n "$APPTAINER_ARGS" ]; then
        # Convert -B flags to comma-separated APPTAINER_BINDPATH
        # Extract all paths after -B flags
        local BIND_PATHS=""
        local ARGS_ARRAY=($APPTAINER_ARGS)
        local i=0
        while [ $i -lt ${#ARGS_ARRAY[@]} ]; do
            if [ "${ARGS_ARRAY[$i]}" = "-B" ] && [ $((i+1)) -lt ${#ARGS_ARRAY[@]} ]; then
                [ -n "$BIND_PATHS" ] && BIND_PATHS="${BIND_PATHS},"
                BIND_PATHS="${BIND_PATHS}${ARGS_ARRAY[$((i+1))]}"
                i=$((i+2))
            else
                i=$((i+1))
            fi
        done
        export APPTAINER_BINDPATH="$BIND_PATHS"
    fi

    # Standard Cache Setup (using /tmp to be safe/fast)
    local CACHE_BASE="/tmp/$(whoami)"

    # Cluster-specific non-bind-path settings
    case "$HOST" in
        *cmslpc*)
            PIXI_DIR="/uscms_data/d3/${USER}/.pixi"
            if [ ! -d "$PIXI_DIR" ]; then
                info "LPC environment detected. Pixi will be installed in ${PIXI_DIR}"
            fi
            ;;
        *runner*)
            PIXI_DIR="/tmp/pixi"
            ;;
        *)
            if [ -z "$APPTAINER_ARGS" ]; then
                warning "Unknown hostname. Using defaults (HOME) for cache/config."
                CACHE_BASE=$HOME
                mkdir -p "$CACHE_BASE"
            fi
            ;;
    esac

    # Cache Configuration
    export APPTAINER_CACHEDIR="${CACHE_BASE}/apptainer_cache"
    export APPTAINER_TMPDIR="${CACHE_BASE}/.apptainer/"
    export MPLCONFIGDIR="${CACHE_BASE}/.config/matplotlib"
    mkdir -p "$APPTAINER_CACHEDIR" "$APPTAINER_TMPDIR" "$MPLCONFIGDIR"
}

# --- LPC Specific Logic ---
setup_lpc_jobqueue() {
    # Only run on LPC
    [[ $(hostname) != *"cmslpc"* ]] && return 0

    # Bootstrap if missing
    if [[ ! -f ".bashrc" || ! -f ".cmslpc-local-conf" ]]; then
        info "Setting up lpcjobqueue configuration..."
        curl -OL https://raw.githubusercontent.com/CoffeaTeam/lpcjobqueue/main/bootstrap.sh
        bash bootstrap.sh
        rm bootstrap.sh shell
    else
        info "lpcjobqueue configuration found. Skipping bootstrap."
    fi

    # Define LPC specific variables and binds
    local LPC_CONDOR_CONFIG="/etc/condor/config.d/01_cmslpc_interactive"
    local LPC_CONDOR_LOCAL="/usr/local/bin/cmslpc-local-conf.py"
    
    export APPTAINER_BINDPATH="${APPTAINER_BINDPATH},${LPC_CONDOR_CONFIG},${LPC_CONDOR_LOCAL}:${LPC_CONDOR_LOCAL}.orig,${PWD}/.cmslpc-local-conf:${LPC_CONDOR_LOCAL}"
}

# --- Helpers ---

_write_pythonstartup() {
    cat > "$1" << 'EOF'
import atexit, os, readline
_hist = os.path.join(os.path.dirname(os.environ.get("PYTHONSTARTUP", "")), ".python_history")
try:
    readline.read_history_file(_hist)
except FileNotFoundError:
    pass
readline.set_history_length(10000)
atexit.register(readline.write_history_file, _hist)
del atexit, os, readline, _hist
EOF
}

# --- Container Functions ---

run_coffea() {
    check_apptainer
    info "Running Coffea container..."
    setup_lpc_jobqueue
    local HOST
    HOST=$(hostname)

    # Check if we need to start the shared Dask daemon
    if [[ " $* " == *"--condor"* || " $* " == *"--slurm"* || " $* " == *"--run-dask"* ]] && \
       [[ " $* " != *" --start-cluster-daemon "* ]]; then
        
        # Determine scheduler JSON path and lock file path
        local SCHEDULER_JSON="/tmp/barista_${USER}/dask_scheduler_${WORKSPACE_HASH}.json"
        local SCHEDULER_LOCK="/tmp/barista_${USER}/dask_daemon_${WORKSPACE_HASH}.lock"
        local DAEMON_LOG="/tmp/barista_${USER}/dask_daemon_${WORKSPACE_HASH}.log"
        mkdir -p "/tmp/barista_${USER}"
        
        # Helper: check if daemon JSON exists and scheduler is reachable
        _daemon_responsive() {
            python3 -c "
import os, json, socket
if os.path.exists('$SCHEDULER_JSON'):
    try:
        with open('$SCHEDULER_JSON') as f:
            addr = json.load(f)['address']
        host, port = addr.replace('tcp://', '').split(':')
        s = socket.create_connection((host, int(port)), timeout=2)
        s.close()
        exit(0)
    except Exception:
        pass
exit(1)
" 2>/dev/null
        }

        # Fast path: shared lock — multiple jobs can check simultaneously
        exec 9>"$SCHEDULER_LOCK"
        flock -s 9
        local _daemon_ok=false
        _daemon_responsive && _daemon_ok=true
        flock -u 9

        if ! $_daemon_ok; then
            # Slow path: exclusive lock to spawn the daemon (only one job does this)
            flock -x 9
            # Re-check under exclusive lock in case another job just spawned it
            if ! _daemon_responsive; then
                info "Shared Dask daemon not running or unresponsive. Spawning in background on host..."
                rm -f "$SCHEDULER_JSON"

                # Reconstruct clean runner.py daemon command
                local DASK_FLAG=""
                local CONFIG_FILE=""
                local TMP_DIR=""

                local i=1
                while [ $i -le $# ]; do
                    eval arg=\$\{$i\}
                    case "$arg" in
                        --condor) DASK_FLAG="--condor" ;;
                        --slurm) DASK_FLAG="--slurm" ;;
                        --run-dask) DASK_FLAG="--run-dask" ;;
                        -c|--config|--configs)
                            next_idx=$((i+1))
                            eval CONFIG_FILE=\$\{$next_idx\}
                            ;;
                        --tmpdir)
                            next_idx=$((i+1))
                            eval TMP_DIR=\$\{$next_idx\}
                            ;;
                    esac
                    i=$((i+1))
                done

                # Spawn daemon in the background on the host
                (
                    exec 9>&-
                    nohup "$0" python runner.py --start-cluster-daemon "$DASK_FLAG" -c "$CONFIG_FILE" ${TMP_DIR:+--tmpdir "$TMP_DIR"} >"$DAEMON_LOG" 2>&1 &
                )
            else
                info "Shared Dask daemon is already running and responsive."
            fi
            flock -u 9

            # Wait outside the lock for the daemon to become responsive
            local count=0
            while [ $count -lt 120 ]; do
                if _daemon_responsive; then
                    info "Shared Dask daemon is now running and responsive."
                    break
                fi
                sleep 1
                count=$((count+1))
            done
            if [ $count -eq 120 ]; then
                warning "Timed out waiting for Dask daemon to become responsive. Proceeding anyway..."
            fi
        else
            info "Shared Dask daemon is already running and responsive."
        fi
        exec 9>&-
    fi

    # 1. Base Flags
    touch "$PWD/.python_history"
    _write_pythonstartup "$PWD/.pythonstartup"
    local FLAGS=( --contain -B "$PWD":/srv --pwd /srv/ -B /tmp:/tmp
        --env XRD_CONNECTIONRETRY=3
        --env XRD_REQUESTTIMEOUT=600
        --env XRD_STREAMTIMEOUT=300
        --env XRD_TIMEOUTRESOLUTION=15
        --env XRD_CONNECTIONWINDOW=30
        --env PYTHONSTARTUP=/srv/.pythonstartup
        --env BARISTA_WORKSPACE_HASH="$WORKSPACE_HASH"
    )
    ulimit -n 65536

    # LPC-Specific Environment Variable
    if [[ $HOST == *"cmslpc"* ]]; then
        FLAGS+=( --env COFFEA_IMAGE_FULL="$COFFEA_IMAGE" )
    fi

    # 2. FALCON / ROGUE / BRIDGES2 Logic
    if [[ $HOST == *falcon* || $HOST == *rogue* || $HOST == *bridges2* || $HOST == *psc* ]]; then
        # Critical: Mirror Bind for Dask
        FLAGS=( -B "$PWD":"$PWD" --pwd "$PWD" --env PYTHONSTARTUP="$PWD/.pythonstartup" )

        # Bind SLURM client binaries so dask-jobqueue SLURMCluster can call
        # sbatch from inside the container.
        if [[ $HOST == *falcon* || $HOST == *rogue* ]] && [ -f /usr/bin/sbatch ]; then
            # Falcon uses custom wraps for newer glibc
            FLAGS+=(
                -B /usr/bin/sbatch -B /usr/bin/squeue -B /usr/bin/scontrol
                -B /usr/lib/x86_64-linux-gnu/slurm-wlm
                -B /usr/lib/x86_64-linux-gnu/libmunge.so.2
                -B /lib/x86_64-linux-gnu/libc.so.6:/host-libc/libc.so.6
                -B /lib/x86_64-linux-gnu/libm.so.6:/host-libc/libm.so.6
                -B /lib/x86_64-linux-gnu/libresolv.so.2:/host-libc/libresolv.so.2
                -B /lib/x86_64-linux-gnu/libnss_files.so.2:/host-libc/libnss_files.so.2
                -B /lib64/ld-linux-x86-64.so.2:/host-libc/ld-linux-x86-64.so.2
                -B /etc/slurm -B /etc/passwd -B /etc/group -B /run/munge
            )
        elif [[ $HOST == *bridges2* || $HOST == *psc* ]]; then
            # Bridges 2 has older glibc than container, so we bind host binaries directly
            FLAGS+=(
                -B "${HOME}/.globus:${HOME}/.globus"
                -B /cvmfs
                --env X509_CERT_DIR=/cvmfs/grid.cern.ch/etc/grid-security/certificates
                -B /usr/bin/sbatch -B /usr/bin/squeue -B /usr/bin/scontrol -B /usr/bin/scancel
                -B /usr/lib64/slurm
                -B /usr/lib64/libmunge.so.2
                -B /var/spool/slurm
                -B /run/munge
                -B /etc/passwd -B /etc/group
            )
        fi

        if [ -n "$SLURM_JOB_ID" ]; then
            # CASE A: Inside a job -> Run locally
            info "Inside Slurm Job ($SLURM_JOB_ID). Running container directly..."
        elif [[ " $* " == *" --slurm "* ]]; then
            # CASE B: Login node + --slurm flag -> Submit scheduler as batch job
            local _ROOT
            _ROOT="$(cd "$(dirname "$0")" && pwd)"
            
            local PARTITION
            local QOS_ARG=()
            local ACCOUNT_ARG=()
            local MEM
            local CPUS
            if [[ $HOST == *bridges2* || $HOST == *psc* ]]; then
                PARTITION="${SLURM_PARTITION:-RM-shared}"
                MEM="${SLURM_MEM:-8000M}"
                CPUS="${SLURM_CPUS:-4}"
                [ -n "${SLURM_ACCOUNT:-}" ] && ACCOUNT_ARG=( -A "${SLURM_ACCOUNT}" )
            else
                PARTITION="${SLURM_PARTITION:-work}"
                QOS_ARG=( --qos="${SLURM_QOS:-cpu_light}" )
                MEM="${SLURM_MEM:-8G}"
                CPUS="${SLURM_CPUS:-4}"
            fi

            local JOB_NAME="${SLURM_JOB_NAME:-barista-scheduler}"
            local LOG_DIR="${_ROOT}/slurm_logs"
            mkdir -p "${LOG_DIR}"

            local TUNNEL_CMD=""
            if [[ -n "${DASK_DASHBOARD_PORT:-}" ]] && [[ $HOST == *falcon* ]]; then
                TUNNEL_CMD="${_ROOT}/software/slurm/open-dask-tunnel.sh && "
                info "Dashboard tunnel: port ${DASK_DASHBOARD_PORT} → http://falcon.phys.cmu.edu:${DASK_DASHBOARD_PORT}"
                info "  Once job starts: ssh -L ${DASK_DASHBOARD_PORT}:localhost:${DASK_DASHBOARD_PORT} tgomezes@falcon.phys.cmu.edu"
            elif [[ -n "${DASK_DASHBOARD_PORT:-}" ]]; then
                info "Dashboard tunnel: port ${DASK_DASHBOARD_PORT} requested"
                info "  Once job starts: ssh -L ${DASK_DASHBOARD_PORT}:localhost:${DASK_DASHBOARD_PORT} tgomezes@bridges2.psc.edu"
            fi

            local SBATCH_ARGS=(
                --partition="${PARTITION}"
                "${QOS_ARG[@]}"
                "${ACCOUNT_ARG[@]}"
                --time="${SLURM_TIME:-12:00:00}"
                --mem="${MEM}"
                --cpus-per-task="${CPUS}"
                --job-name="${JOB_NAME}"
                --output="${LOG_DIR}/scheduler-%j.out"
                --error="${LOG_DIR}/scheduler-%j.err"
            )
            [[ -n "${DASK_DASHBOARD_PORT:-}" ]] && SBATCH_ARGS+=(--export=ALL,DASK_DASHBOARD_PORT="${DASK_DASHBOARD_PORT}")

            local CMD="${TUNNEL_CMD}cd ${_ROOT} && $0 $*"
            info "Submitting scheduler job: partition=${PARTITION} time=${SLURM_TIME:-12:00:00} mem=${MEM} cpus=${CPUS}"
            sbatch "${SBATCH_ARGS[@]}" --wrap="${CMD}"
            info "Monitor with: squeue --me"
            info "  tail -f ${LOG_DIR}/scheduler-<JOBID>.out"
            return
        else
            # CASE C: Login node, no --slurm -> Submit interactive job
            info "Not in a job. Launching interactive Slurm session..."
            if [[ $HOST == *bridges2* || $HOST == *psc* ]]; then
                local ACCOUNT_ARG=()
                [ -n "${SLURM_ACCOUNT:-}" ] && ACCOUNT_ARG=( -A "${SLURM_ACCOUNT}" )
                srun --pty --partition=RM-shared "${ACCOUNT_ARG[@]}" --time=02:00:00 --cpus-per-task=2 --mem=4000M "$0" "$@"
            else
                srun --pty --partition=work --time=04:00:00 --cpus-per-task=1 --mem=2G "$0" "$@"
            fi
            return # Stop execution on login node
        fi
    fi

    add_x509_proxy_flags "$HOST" FLAGS

    # 3. EXECUTION LOGIC
    if [ -z "$*" ]; then
        # --- INTERACTIVE SHELL ---
        if [[ $HOST == *"cmslpc"* ]]; then
            info "Opening interactive shell (LPC mode)..."
            APPTAINER_SHELL=$(which bash) "${APPTAINER_CMD:-apptainer}" exec "${FLAGS[@]}" "$COFFEA_IMAGE" /bin/bash --rcfile /srv/.bashrc
        else
            info "Opening interactive shell..."
            APPTAINER_SHELL=$(which bash) "${APPTAINER_CMD:-apptainer}" exec "${FLAGS[@]}" "$COFFEA_IMAGE" /bin/bash
        fi
    else
        # --- COMMAND EXECUTION ---
        local CMD="$*"
        if [[ $HOST == *"cmslpc"* ]]; then
            info "Running command (LPC mode)..."
            APPTAINER_SHELL=$(which bash) "${APPTAINER_CMD:-apptainer}" exec "${FLAGS[@]}" "$COFFEA_IMAGE" /bin/bash -c "source /srv/.bashrc && $CMD"
        else
            info "Running command..."
            APPTAINER_SHELL=$(which bash) "${APPTAINER_CMD:-apptainer}" exec "${FLAGS[@]}" "$COFFEA_IMAGE" /bin/bash -c "$CMD"
        fi
    fi
}

run_coffea_dev() {
    check_apptainer
    info "Running Dev Coffea0.7 container..."
    setup_lpc_jobqueue
    local HOST
    HOST=$(hostname)

    # 1. Base Flags
    touch "$PWD/.python_history"
    _write_pythonstartup "$PWD/.pythonstartup"
    local FLAGS=( --contain -B "$PWD":/srv --pwd /srv/ -B /tmp:/tmp
        --env XRD_CONNECTIONRETRY=3
        --env XRD_REQUESTTIMEOUT=600
        --env XRD_STREAMTIMEOUT=300
        --env XRD_TIMEOUTRESOLUTION=15
        --env XRD_CONNECTIONWINDOW=30
        --env PYTHONSTARTUP=/srv/.pythonstartup
        --env BARISTA_WORKSPACE_HASH="$WORKSPACE_HASH"
    )
    ulimit -n 65536

    # LPC-Specific Environment Variable
    if [[ $HOST == *"cmslpc"* ]]; then
        FLAGS+=( --env COFFEA_IMAGE_FULL="$DEV_COFFEA0_7_IMAGE" )
    fi

    # 2. FALCON / ROGUE / BRIDGES2 Logic
    if [[ $HOST == *falcon* || $HOST == *rogue* || $HOST == *bridges2* || $HOST == *psc* ]]; then
        # Critical: Mirror Bind for Dask
        FLAGS=( -B "$PWD":"$PWD" --pwd "$PWD" --env PYTHONSTARTUP="$PWD/.pythonstartup" )

        if [[ $HOST == *falcon* || $HOST == *rogue* ]] && [ -f /usr/bin/sbatch ]; then
            # Falcon uses custom wraps for newer glibc
            FLAGS+=(
                -B /usr/bin/sbatch -B /usr/bin/squeue -B /usr/bin/scontrol
                -B /usr/lib/x86_64-linux-gnu/slurm-wlm
                -B /usr/lib/x86_64-linux-gnu/libmunge.so.2
                -B /lib/x86_64-linux-gnu/libc.so.6:/host-libc/libc.so.6
                -B /lib/x86_64-linux-gnu/libm.so.6:/host-libc/libm.so.6
                -B /lib/x86_64-linux-gnu/libresolv.so.2:/host-libc/libresolv.so.2
                -B /lib/x86_64-linux-gnu/libnss_files.so.2:/host-libc/libnss_files.so.2
                -B /lib64/ld-linux-x86-64.so.2:/host-libc/ld-linux-x86-64.so.2
                -B /etc/slurm -B /etc/passwd -B /etc/group -B /run/munge
            )
        elif [[ $HOST == *bridges2* || $HOST == *psc* ]]; then
            # Bridges 2 has older glibc than container, so we bind host binaries directly
            FLAGS+=(
                -B "${HOME}/.globus:${HOME}/.globus"
                -B /cvmfs
                --env X509_CERT_DIR=/cvmfs/grid.cern.ch/etc/grid-security/certificates
                -B /usr/bin/sbatch -B /usr/bin/squeue -B /usr/bin/scontrol -B /usr/bin/scancel
                -B /usr/lib64/slurm
                -B /usr/lib64/libmunge.so.2
                -B /var/spool/slurm
                -B /run/munge
                -B /etc/passwd -B /etc/group
            )
        fi

        if [ -n "$SLURM_JOB_ID" ]; then
            # CASE A: Inside a job -> Run locally
            info "Inside Slurm Job ($SLURM_JOB_ID). Running Dev Coffea0.7 container directly..."
        elif [[ " $* " == *" --slurm "* ]]; then
            # CASE B: Login node + --slurm flag -> Submit scheduler as batch job
            local _ROOT
            _ROOT="$(cd "$(dirname "$0")" && pwd)"
            
            local PARTITION
            local QOS_ARG=()
            local ACCOUNT_ARG=()
            local MEM
            local CPUS
            if [[ $HOST == *bridges2* || $HOST == *psc* ]]; then
                PARTITION="${SLURM_PARTITION:-RM-shared}"
                MEM="${SLURM_MEM:-8000M}"
                CPUS="${SLURM_CPUS:-4}"
                [ -n "${SLURM_ACCOUNT:-}" ] && ACCOUNT_ARG=( -A "${SLURM_ACCOUNT}" )
            else
                PARTITION="${SLURM_PARTITION:-work}"
                QOS_ARG=( --qos="${SLURM_QOS:-cpu_light}" )
                MEM="${SLURM_MEM:-8G}"
                CPUS="${SLURM_CPUS:-4}"
            fi

            local JOB_NAME="${SLURM_JOB_NAME:-barista-scheduler}"
            local LOG_DIR="${_ROOT}/slurm_logs"
            mkdir -p "${LOG_DIR}"

            local TUNNEL_CMD=""
            if [[ -n "${DASK_DASHBOARD_PORT:-}" ]] && [[ $HOST == *falcon* ]]; then
                TUNNEL_CMD="${_ROOT}/software/slurm/open-dask-tunnel.sh && "
                info "Dashboard tunnel: port ${DASK_DASHBOARD_PORT} → http://falcon.phys.cmu.edu:${DASK_DASHBOARD_PORT}"
                info "  Once job starts: ssh -L ${DASK_DASHBOARD_PORT}:localhost:${DASK_DASHBOARD_PORT} tgomezes@falcon.phys.cmu.edu"
            elif [[ -n "${DASK_DASHBOARD_PORT:-}" ]]; then
                info "Dashboard tunnel: port ${DASK_DASHBOARD_PORT} requested"
                info "  Once job starts: ssh -L ${DASK_DASHBOARD_PORT}:localhost:${DASK_DASHBOARD_PORT} tgomezes@bridges2.psc.edu"
            fi

            local SBATCH_ARGS=(
                --partition="${PARTITION}"
                "${QOS_ARG[@]}"
                "${ACCOUNT_ARG[@]}"
                --time="${SLURM_TIME:-12:00:00}"
                --mem="${MEM}"
                --cpus-per-task="${CPUS}"
                --job-name="${JOB_NAME}"
                --output="${LOG_DIR}/scheduler-%j.out"
                --error="${LOG_DIR}/scheduler-%j.err"
            )
            [[ -n "${DASK_DASHBOARD_PORT:-}" ]] && SBATCH_ARGS+=(--export=ALL,DASK_DASHBOARD_PORT="${DASK_DASHBOARD_PORT}")

            local CMD="${TUNNEL_CMD}cd ${_ROOT} && $0 dev $*"
            info "Submitting scheduler job: partition=${PARTITION} time=${SLURM_TIME:-12:00:00} mem=${MEM} cpus=${CPUS}"
            sbatch "${SBATCH_ARGS[@]}" --wrap="${CMD}"
            info "Monitor with: squeue --me"
            info "  tail -f ${LOG_DIR}/scheduler-<JOBID>.out"
            return
        else
            # CASE C: Login node, no --slurm -> Submit interactive job
            info "Not in a job. Launching interactive Slurm session (Dev Coffea0.7)..."
            if [[ $HOST == *bridges2* || $HOST == *psc* ]]; then
                local ACCOUNT_ARG=()
                [ -n "${SLURM_ACCOUNT:-}" ] && ACCOUNT_ARG=( -A "${SLURM_ACCOUNT}" )
                srun --pty --partition=RM-shared "${ACCOUNT_ARG[@]}" --time=02:00:00 --cpus-per-task=2 --mem=4000M "$0" dev "$@"
            else
                srun --pty --partition=work --time=04:00:00 --mem=2G "$0" dev "$@"
            fi
            return # Stop execution on login node
        fi
    fi

    add_x509_proxy_flags "$HOST" FLAGS

    # 3. EXECUTION LOGIC
    if [ -z "$*" ]; then
        # --- INTERACTIVE SHELL ---
        if [[ $HOST == *"cmslpc"* ]]; then
            info "Opening interactive shell (LPC mode, Dev Coffea0.7)..."
            APPTAINER_SHELL=$(which bash) "${APPTAINER_CMD:-apptainer}" exec "${FLAGS[@]}" "$DEV_COFFEA0_7_IMAGE" /bin/bash --rcfile /srv/.bashrc
        else
            info "Opening interactive shell (Dev Coffea0.7)..."
            APPTAINER_SHELL=$(which bash) "${APPTAINER_CMD:-apptainer}" exec "${FLAGS[@]}" "$DEV_COFFEA0_7_IMAGE" /bin/bash
        fi
    else
        # --- COMMAND EXECUTION ---
        local CMD="$*"
        if [[ $HOST == *"cmslpc"* ]]; then
            info "Running command (LPC mode, Dev Coffea0.7)..."
            APPTAINER_SHELL=$(which bash) "${APPTAINER_CMD:-apptainer}" exec "${FLAGS[@]}" "$DEV_COFFEA0_7_IMAGE" /bin/bash -c "source /srv/.bashrc && $CMD"
        else
            info "Running command (Dev Coffea0.7)..."
            APPTAINER_SHELL=$(which bash) "${APPTAINER_CMD:-apptainer}" exec "${FLAGS[@]}" "$DEV_COFFEA0_7_IMAGE" /bin/bash -c "$CMD"
        fi
    fi
}

