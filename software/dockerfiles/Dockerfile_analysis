FROM docker.io/coffeateam/coffea-dask-almalinux9:2025.12.0-py3.12

RUN dnf install -y poppler-utils gcc gcc-c++ python3-devel && \
    dnf clean all && rm -rf /var/cache/dnf && \
    pip install pycodestyle memory-profiler fsspec-xrootd omegaconf dbs3-client narwhals \
                xgboost onnxruntime "tritonclient[grpc]"

# 1. Create the specific directory Slurm expects for plugins (for falcon)
RUN mkdir -p /usr/lib/x86_64-linux-gnu/slurm-wlm
RUN mkdir -p /host
