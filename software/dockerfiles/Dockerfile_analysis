FROM docker.io/mambaorg/micromamba:latest

USER root

# Add conda environment to PATH
ENV PATH=/opt/conda/bin:$PATH

# Install system dependencies (poppler-utils)
RUN apt-get update && \
    apt-get install -y --no-install-recommends poppler-utils && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Switch back to mambauser for conda installations
USER mambauser

# Install packages from conda-forge
# Note: we need python, pip, coffea, uproot, awkward, vector, hist, dask, dask-jobqueue, dask-awkward, xrootd, voms, ca-policy-lcg, htcondor, nodejs, and pytorch
RUN micromamba install -y -n base -c conda-forge \
    python=3.12 \
    pip \
    coffea=2025.12.0 \
    uproot \
    awkward \
    vector \
    hist \
    dask \
    dask-jobqueue \
    dask-awkward \
    xrootd \
    voms \
    ca-policy-lcg \
    htcondor \
    nodejs \
    pytorch \
    rucio-clients \
    fastjet \
    && micromamba clean --all --yes

# Install additional python packages via pip using micromamba run
RUN micromamba run -n base python -m pip install --no-cache-dir \
    pycodestyle \
    memory-profiler \
    fsspec-xrootd \
    omegaconf \
    dbs3-client \
    narwhals \
    xgboost \
    onnxruntime \
    "tritonclient[grpc]" \
    flask \
    mplhep \
    pytest \
    awkward-pandas \
    readchar \
    pyvis

# Create directories as root
USER root
RUN mkdir -p /etc/grid-security && \
    ln -sf /opt/conda/etc/grid-security/certificates /etc/grid-security/certificates && \
    mkdir -p /usr/lib/x86_64-linux-gnu/slurm-wlm && \
    mkdir -p /host