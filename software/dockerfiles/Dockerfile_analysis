# Slimmer Analysis Container Build From Scratch
FROM docker.io/mambaorg/micromamba:latest

USER root

# Add conda environment to PATH
ENV PATH=/opt/conda/bin:$PATH
ENV VOMS_PROXY_INIT_DONT_VERIFY_AC=1

# Install system dependencies (poppler-utils, git, curl)
RUN apt-get update && \
    apt-get install -y --no-install-recommends poppler-utils git curl && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Switch back to mambauser for conda installations
USER mambauser

# Install packages from conda-forge
# Note: we need python, pip, coffea, uproot, awkward, vector, hist, dask, dask-jobqueue, dask-awkward, xrootd, voms, htcondor, nodejs, and pytorch
RUN micromamba install -y -n base -c conda-forge \
    python=3.12 \
    pip \
    coffea=2025.12.0 \
    uproot \
    awkward \
    vector \
    hist \
    dask \
    distributed=2025.3.1 \
    bokeh=3.8.2 \
    dask-jobqueue \
    dask-awkward \
    xrootd \
    voms \
    htcondor \
    nodejs \
    "pytorch=2.5.1" \
    rucio-clients \
    fastjet \
    && micromamba clean --all --yes

# Install additional python packages via pip using micromamba run
RUN micromamba run -n base python -m pip install --no-cache-dir \
    pycodestyle \
    memory-profiler \
    fsspec-xrootd \
    omegaconf \
    dbs3-client \
    narwhals \
    xgboost \
    onnxruntime \
    "tritonclient[grpc]" \
    flask \
    mplhep \
    pytest \
    awkward-pandas \
    readchar \
    pyvis \
    git+https://github.com/CoffeaTeam/lpcjobqueue.git@v0.5.0 \
    conda-pack

# Create directories as root
USER root
RUN mkdir -p /etc/grid-security && \
    mkdir -p /usr/lib/x86_64-linux-gnu/slurm-wlm && \
    mkdir -p /host

# Copy VOMS and Grid Certificate configs from official coffea base image
COPY --from=docker.io/coffeateam/coffea-dask-almalinux9:2025.12.0-py3.12 /etc/vomses /etc/vomses
COPY --from=docker.io/coffeateam/coffea-dask-almalinux9:2025.12.0-py3.12 /etc/grid-security/vomsdir /etc/grid-security/vomsdir
COPY --from=docker.io/coffeateam/coffea-dask-almalinux9:2025.12.0-py3.12 /usr/local/etc/grid-security/certificates /etc/grid-security/certificates

# Create a wrapper for voms-proxy-info to automatically append -dont-verify-ac
RUN mv /opt/conda/bin/voms-proxy-info /opt/conda/bin/voms-proxy-info.real && \
    echo '#!/bin/bash' > /opt/conda/bin/voms-proxy-info && \
    echo 'exec /opt/conda/bin/voms-proxy-info.real -dont-verify-ac "$@"' >> /opt/conda/bin/voms-proxy-info && \
    chmod +x /opt/conda/bin/voms-proxy-info

# Create sitecustomize.py to allowlist numpy scalar and arrays in PyTorch 2.6+ safe unpickling
COPY software/dockerfiles/sitecustomize.py /opt/conda/lib/python3.12/site-packages/sitecustomize.py

# Create htcondor->htcondor2 compatibility shim for lpcjobqueue
RUN mkdir -p /opt/conda/lib/python3.12/site-packages/htcondor
COPY software/dockerfiles/htcondor_shim.py /opt/conda/lib/python3.12/site-packages/htcondor/__init__.py