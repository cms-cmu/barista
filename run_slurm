#!/usr/bin/env bash
# run_slurm — submit a runner.py --slurm command as a batch SLURM job on falcon.
#
# Usage:  ./run_slurm python runner.py -p <proc.py> -c <cfg.yml> ... --slurm
#
# Submits the full run_container command as an sbatch job so the Dask scheduler
# (started by --slurm) runs on a compute node. run_container detects SLURM_JOB_ID
# and runs apptainer directly; the container has SLURM binaries bound in so
# SLURMCluster can submit worker jobs via bin/sbatch.
#
# Environment variables (override defaults):
#   SLURM_PARTITION      partition for the scheduler job (default: work)
#   SLURM_QOS            QoS for the scheduler job (default: cpu_light)
#   SLURM_TIME           wall-clock time for the scheduler job (default: 12:00:00)
#   SLURM_MEM            memory for the scheduler job (default: 8G)
#   SLURM_CPUS           CPUs for the scheduler job (default: 4)
#   SLURM_JOB_NAME       SLURM job name (default: barista-scheduler)
#   DASK_DASHBOARD_PORT  port in 10200-10300 to expose the Dask dashboard on falcon
#                        (optional; omit to skip the dashboard tunnel)

set -euo pipefail

BARISTA_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PARTITION="${SLURM_PARTITION:-work}"
QOS="${SLURM_QOS:-cpu_light}"
TIME="${SLURM_TIME:-12:00:00}"
MEM="${SLURM_MEM:-8G}"
CPUS="${SLURM_CPUS:-4}"
JOB_NAME="${SLURM_JOB_NAME:-barista-scheduler}"
LOG_DIR="${BARISTA_ROOT}/slurm_dask_logs"
mkdir -p "${LOG_DIR}"

# Prepend tunnel setup if DASK_DASHBOARD_PORT is set
if [[ -n "${DASK_DASHBOARD_PORT:-}" ]]; then
    TUNNEL_CMD="${BARISTA_ROOT}/bin/open-dask-tunnel.sh && "
    echo "Dashboard tunnel: port ${DASK_DASHBOARD_PORT} → http://falcon.phys.cmu.edu:${DASK_DASHBOARD_PORT}"
else
    TUNNEL_CMD=""
fi

CMD="${TUNNEL_CMD}cd ${BARISTA_ROOT} && ./run_container $*"

echo "Submitting scheduler job: partition=${PARTITION} qos=${QOS} time=${TIME} mem=${MEM} cpus=${CPUS}"
echo "Command: ${CMD}"

SBATCH_ARGS=(
    --partition="${PARTITION}"
    --qos="${QOS}"
    --time="${TIME}"
    --mem="${MEM}"
    --cpus-per-task="${CPUS}"
    --job-name="${JOB_NAME}"
    --output="${LOG_DIR}/scheduler-%j.out"
    --error="${LOG_DIR}/scheduler-%j.err"
)
[[ -n "${DASK_DASHBOARD_PORT:-}" ]] && SBATCH_ARGS+=(--export=ALL,DASK_DASHBOARD_PORT="${DASK_DASHBOARD_PORT}")

sbatch "${SBATCH_ARGS[@]}" --wrap="${CMD}"

echo "Job submitted. Monitor with:"
echo "  squeue --me"
echo "  tail -f ${LOG_DIR}/scheduler-<JOBID>.out"
